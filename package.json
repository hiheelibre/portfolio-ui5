{
  "name": "portfolio.dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Notion 빌드 타임 동기화 기반 Enterprise Developer Portfolio",
  "keywords": ["ui5", "openui5", "sapui5"],
  "main": "webapp/index.html",
  "dependencies": {
    "@notionhq/client": "^5.22.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@sap/ux-ui5-tooling": "1",
    "@ui5/cli": "^4.0.33",
    "rimraf": "6.0.1",
    "serve": "^14.2.6"
  },
  "scripts": {
    "start": "fiori run --open \"index.html?sap-ui-xx-viewCache=false\"",
    "start-flp": "fiori run --open \"test/flpSandbox.html?sap-ui-xx-viewCache=false#app-tile\"",
    "start-local": "fiori run --config ./ui5-local.yaml --open \"index.html?sap-ui-xx-viewCache=false\"",
    "build": "ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "deploy": "fiori verify",
    "deploy-config": "fiori add deploy-config",
    "notion:test": "node scripts/test-notion.js",
    "notion:modules": "node scripts/sync-notion-modules.js",
    "notion:sync": "node scripts/sync-notion-posts.js",
    "content:sync": "npm run notion:modules && npm run notion:sync",
    "content:validate": "node scripts/validate-portfolio-content.js",
    "portfolio:build": "npm run notion:modules && npm run notion:sync && npm run content:validate && npm run build",
    "preview:dist": "serve dist",
    "notion:deploy": "node scripts/trigger-netlify-build.js"
  },
  "sapuxLayer": "CUSTOMER_BASE"
}
