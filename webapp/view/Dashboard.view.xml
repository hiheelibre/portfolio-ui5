<!--
  Dashboard.view.xml — Enterprise Developer Portfolio
  - Dashboard: 자기소개 목업(dashboard_self_intro_mockup.html) 기준 7섹션 구성
    Hero/Identity → About Me → Career Story → Core Strengths → How I Work
    → Selected Projects(Notion modules.json 동적) → Closing CTA
  - 데이터: 빌드 타임 정적 JSON (model/modules.json, model/posts/**, model/profile.json)
  - 라우팅: #dashboard / #module/{Code} / #post/{Module}/{PostId} / #skills / #career
-->
<mvc:View
    controllerName="portfolio.dashboard.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">

    <Shell appWidthLimited="false" class="pfShellWrap">
        <App id="appRoot">
            <pages>
                <Page id="rootPage" showHeader="false" showNavButton="false"
                      enableScrolling="false" backgroundDesign="Solid" class="pfRootPage">
                    <content>

                        <!-- 모바일 전용 상단 헤더 -->
                        <HBox id="mobileHeader" class="pfMobileHeader" alignItems="Center"
                              justifyContent="SpaceBetween">
                            <HBox alignItems="Center" class="pfMobileLogo">
                                <Text text="{site>/brand/logoLead}&#160;" class="pfLogoText"/>
                                <Text text="{site>/brand/logoAccent}" class="pfLogoAccent"/>
                            </HBox>
                            <Button id="hamburgerBtn" icon="sap-icon://menu2"
                                    press=".onToggleDrawer" class="pfHamburger"
                                    tooltip="메뉴 열기"/>
                        </HBox>

                        <!-- Drawer 오버레이 -->
                        <VBox id="drawerOverlay" class="pfDrawerOverlay"/>

                        <FlexBox renderType="Bare" class="pfShell" height="100%" width="100%">

                            <!-- ═══ 사이드바 ═══ -->
                            <VBox id="sidebar" class="pfSidebar">
                                <VBox class="pfLogoArea">
                                    <HBox>
                                        <Text text="{site>/brand/logoLead}&#160;" class="pfLogoText"/>
                                        <Text text="{site>/brand/logoAccent}" class="pfLogoAccent"/>
                                    </HBox>
                                    <Text text="{site>/brand/caption}" class="pfLogoCaption"/>
                                </VBox>

                                <VBox class="pfNavScroll">
                                    <Button id="navDashboard" text="Dashboard"
                                            press=".onNavDashboard" class="pfNavItem pfActive"/>

                                    <!-- 대분류 그룹: modules.json Group/GroupOrder 기준 동적 생성 -->
                                    <VBox id="navGroups" items="{vm>/nav/groups}" renderType="Bare">
                                        <VBox renderType="Bare" class="pfNavGroup">
                                            <Text text="{vm>title}" class="pfNavGroupTitle"/>
                                            <VBox items="{vm>items}" renderType="Bare">
                                                <Button text="{vm>label}" press=".onNavModule" class="pfNavSubItem"/>
                                            </VBox>
                                        </VBox>
                                    </VBox>

                                    <Text text="Information" class="pfNavGroupTitle"/>
                                    <Button id="navSkills" text="Technical Skills"
                                            press=".onNavSkills" class="pfNavItem"/>
                                    <Button id="navCareer" text="Career &amp; Contact"
                                            press=".onNavCareer" class="pfNavItem"/>
                                </VBox>

                                <Text text="{site>/brand/footer}" class="pfSidebarFooter"/>
                            </VBox>

                            <!-- ═══ 메인: NavContainer ═══ -->
                            <NavContainer id="navCon" class="pfMain" height="100%"
                                          afterNavigate=".onAfterNavigate">

                                <!-- ── 1. DASHBOARD ── -->
                                <ScrollContainer id="pageDashboard" height="100%" width="100%"
                                                 vertical="true" horizontal="false">
                                    <VBox id="dashboardInner" class="pfPageInner">
                                        <VBox class="pfContainer">

                                            <!-- 1) Hero / 개발자 정체성 -->
                                            <FlexBox id="heroBox" renderType="Bare"
                                                     class="pfHero pfPreEnter pfDelay0">
                                                <VBox class="pfHeroCopy">
                                                    <Text text="{profile>/hero/eyebrow}" class="pfEyebrow"/>
                                                    <FormattedText htmlText="{path: 'profile>/hero/title', formatter: '.fmtBr'}"
                                                                   class="pfHeroTitle"/>
                                                    <Text text="{profile>/hero/description}" wrapping="true" class="pfHeroIntro"/>
                                                    <HBox class="pfHeroActions" wrap="Wrap">
                                                        <Button text="{profile>/hero/primaryAction}"
                                                                press=".onHeroProjects" class="pfBtn pfBtnPrimary"/>
                                                        <Button text="{profile>/hero/secondaryAction}"
                                                                press=".onHeroCareer" class="pfBtn"/>
                                                    </HBox>
                                                </VBox>

                                                <VBox class="pfIdentityCard">
                                                    <Text text="{profile>/identity/label}" class="pfIdentityLabel"/>
                                                    <FormattedText htmlText="{path: 'profile>/identity/role', formatter: '.fmtBr'}"
                                                                   class="pfIdentityRole"/>
                                                    <VBox items="{profile>/identity/rows}" renderType="Bare"
                                                          class="pfIdentityList">
                                                        <HBox class="pfIdentityRow" alignItems="Start">
                                                            <Text text="{profile>key}" class="pfIdentityKey"/>
                                                            <Text text="{profile>value}" wrapping="true" class="pfIdentityValue"/>
                                                        </HBox>
                                                    </VBox>
                                                    <HBox items="{profile>/identity/tags}" wrap="Wrap" class="pfIdentityTags">
                                                        <Text text="{profile>text}" class="pfTag"/>
                                                    </HBox>
                                                </VBox>
                                            </FlexBox>

                                            <!-- 2) About Me -->
                                            <VBox id="aboutSection" class="pfSection pfPreEnter pfDelay100">
                                                <HBox class="pfSectionHead" justifyContent="SpaceBetween"
                                                      alignItems="End" width="100%" wrap="Wrap">
                                                    <Title text="{profile>/about/sectionTitle}" level="H2" class="pfSectionTitle"/>
                                                    <Text text="{profile>/about/sectionDesc}" class="pfSectionNote"/>
                                                </HBox>
                                                <FlexBox renderType="Bare" class="pfIntroGrid">
                                                    <VBox class="pfIntroCard">
                                                        <Title text="{profile>/about/heading}" level="H3"
                                                               wrapping="true" class="pfCardHeading"/>
                                                        <VBox items="{profile>/about/paragraphs}" renderType="Bare">
                                                            <Text text="{profile>text}" wrapping="true" class="pfIntroPara"/>
                                                        </VBox>
                                                        <Text text="{profile>/hero/philosophy}" wrapping="true" class="pfQuote"/>
                                                        <Text text="{profile>/about/quote}" wrapping="true" class="pfQuoteSub"/>
                                                    </VBox>
                                                    <VBox class="pfDirectionCard">
                                                        <Title text="{profile>/about/directionTitle}" level="H3" class="pfCardHeading"/>
                                                        <VBox items="{profile>/about/directions}" renderType="Bare"
                                                              class="pfDirectionList">
                                                            <HBox class="pfDirectionItem" alignItems="Start">
                                                                <Text text="{profile>num}" class="pfDirectionNum"/>
                                                                <VBox class="pfDirectionBody">
                                                                    <Text text="{profile>title}" class="pfDirectionTitle"/>
                                                                    <Text text="{profile>desc}" wrapping="true" class="pfDirectionDesc"/>
                                                                </VBox>
                                                            </HBox>
                                                        </VBox>
                                                    </VBox>
                                                </FlexBox>
                                            </VBox>

                                            <!-- 3) Career Story -->
                                            <VBox id="storySection" class="pfSection pfPreEnter pfDelay200">
                                                <HBox class="pfSectionHead" justifyContent="SpaceBetween"
                                                      alignItems="End" width="100%" wrap="Wrap">
                                                    <Title text="{profile>/sections/story/title}" level="H2" class="pfSectionTitle"/>
                                                    <Text text="{profile>/sections/story/desc}" class="pfSectionNote"/>
                                                </HBox>
                                                <FlexBox renderType="Bare" items="{profile>/journey}" class="pfStoryGrid">
                                                    <VBox class="pfStoryCard">
                                                        <Text text="{profile>index}" class="pfStoryIndex"/>
                                                        <Title text="{profile>title}" level="H3" wrapping="true" class="pfStoryTitle"/>
                                                        <Text text="{profile>desc}" wrapping="true" class="pfStoryDesc"/>
                                                        <Text text="{profile>badge}" class="pfStoryBadge">
                                                            <customData>
                                                                <core:CustomData key="type" writeToDom="true" value="{profile>badgeType}"/>
                                                            </customData>
                                                        </Text>
                                                    </VBox>
                                                </FlexBox>
                                            </VBox>

                                            <!-- 4) Core Strengths -->
                                            <VBox id="strengthSection" class="pfSection">
                                                <HBox class="pfSectionHead" justifyContent="SpaceBetween"
                                                      alignItems="End" width="100%" wrap="Wrap">
                                                    <Title text="{profile>/sections/strengths/title}" level="H2" class="pfSectionTitle"/>
                                                    <Text text="{profile>/sections/strengths/desc}" class="pfSectionNote"/>
                                                </HBox>
                                                <FlexBox renderType="Bare" items="{profile>/strengths}" class="pfStrengthGrid">
                                                    <VBox class="pfStrengthCard">
                                                        <Text text="{profile>num}" class="pfStrengthIcon"/>
                                                        <Title text="{profile>title}" level="H3" wrapping="true" class="pfStrengthTitle"/>
                                                        <Text text="{profile>desc}" wrapping="true" class="pfStrengthDesc"/>
                                                        <Text text="{profile>proof}" wrapping="true" class="pfStrengthProof"/>
                                                    </VBox>
                                                </FlexBox>
                                            </VBox>

                                            <!-- 5) How I Work -->
                                            <VBox id="workSection" class="pfSection">
                                                <HBox class="pfSectionHead" justifyContent="SpaceBetween"
                                                      alignItems="End" width="100%" wrap="Wrap">
                                                    <Title text="{profile>/work/sectionTitle}" level="H2" class="pfSectionTitle"/>
                                                    <Text text="{profile>/work/sectionDesc}" class="pfSectionNote"/>
                                                </HBox>
                                                <FlexBox renderType="Bare" class="pfApproach">
                                                    <VBox class="pfApproachCopy">
                                                        <FormattedText htmlText="{path: 'profile>/work/title', formatter: '.fmtBr'}"
                                                                       class="pfApproachTitle"/>
                                                        <Text text="{profile>/work/desc}" wrapping="true" class="pfApproachDesc"/>
                                                    </VBox>
                                                    <VBox items="{profile>/workProcess}" renderType="Bare" class="pfApproachSteps">
                                                        <HBox class="pfApproachStep" alignItems="Center">
                                                            <Text text="{profile>step}" class="pfApproachStepNo"/>
                                                            <VBox class="pfApproachStepBody">
                                                                <Text text="{profile>title}" class="pfApproachStepTitle"/>
                                                                <Text text="{profile>desc}" wrapping="true" class="pfApproachStepDesc"/>
                                                            </VBox>
                                                        </HBox>
                                                    </VBox>
                                                </FlexBox>
                                            </VBox>

                                            <!-- 6) Selected Projects : Notion modules.json 동적 카드 -->
                                            <VBox id="projectSection" class="pfSection">
                                                <HBox class="pfSectionHead" justifyContent="SpaceBetween"
                                                      alignItems="End" width="100%" wrap="Wrap">
                                                    <Title text="{profile>/sections/projects/title}" level="H2" class="pfSectionTitle"/>
                                                    <Text text="{profile>/sections/projects/desc}" class="pfSectionNote"/>
                                                </HBox>
                                                <List id="cardList" items="{vm>/cards}" showSeparators="None"
                                                      backgroundDesign="Transparent" class="pfProjectGrid"
                                                      itemPress=".onCardPress">
                                                    <CustomListItem type="Active" class="pfProjectCard">
                                                        <VBox class="pfProjectCardInner">
                                                            <HBox justifyContent="SpaceBetween" alignItems="Start" width="100%">
                                                                <Text text="{vm>groupLabel}" class="pfBadge pfBadgeDomain">
                                                                    <customData>
                                                                        <core:CustomData key="domain" writeToDom="true" value="{vm>domain}"/>
                                                                    </customData>
                                                                </Text>
                                                                <Text text="{vm>index}" class="pfProjectIndex"/>
                                                            </HBox>
                                                            <Title text="{vm>title}" level="H3" wrapping="true" class="pfProjectCardTitle"/>
                                                            <Text text="{vm>summary}" wrapping="true" class="pfProjectCardDesc"/>
                                                            <HBox justifyContent="SpaceBetween" alignItems="Center"
                                                                  width="100%" class="pfProjectCardBottom">
                                                                <Text text="{vm>metaLabel}" class="pfProjectMeta"/>
                                                                <Text text="&#8594;" class="pfArrow"/>
                                                            </HBox>
                                                        </VBox>
                                                    </CustomListItem>
                                                </List>
                                                <VBox visible="{= ${vm>/cards}.length === 0 }" class="pfEmptyState">
                                                    <Text text="아직 Published 상태의 프로젝트가 없습니다." class="pfEmptyText"/>
                                                    <Text text="Notion Modules DB에서 모듈을 Published로 변경하고 빌드하면 이 영역에 자동으로 나타납니다."
                                                          class="pfEmptySub"/>
                                                </VBox>
                                            </VBox>

                                            <!-- 7) Closing CTA -->
                                            <FlexBox id="closingBanner" renderType="Bare" class="pfClosing">
                                                <VBox class="pfClosingCopy">
                                                    <Title text="{profile>/closing/title}" level="H2"
                                                           wrapping="true" class="pfClosingTitle"/>
                                                    <Text text="{profile>/closing/desc}" wrapping="true" class="pfClosingDesc"/>
                                                </VBox>
                                                <HBox class="pfClosingActions" wrap="Wrap">
                                                    <Button text="{profile>/closing/skillsLabel}"
                                                            press=".onNavSkills" class="pfBtn pfBtnGhost"/>
                                                    <Button text="{profile>/closing/careerLabel}"
                                                            press=".onNavCareer" class="pfBtn pfBtnLime"/>
                                                </HBox>
                                            </FlexBox>

                                        </VBox>
                                    </VBox>
                                </ScrollContainer>

                                <!-- ── 2. MODULE 상세 (modules.json 바인딩) ── -->
                                <ScrollContainer id="pageModule" height="100%" width="100%"
                                                 vertical="true" horizontal="false">
                                    <VBox id="moduleInner" class="pfPageInner">

                                        <HBox class="pfProjHeader" justifyContent="SpaceBetween"
                                              alignItems="Start" width="100%" wrap="Wrap">
                                            <VBox class="pfProjHeaderCopy">
                                                <Text text="{vm>/module/eyebrow}" class="pfProjCategory"/>
                                                <Title text="{vm>/module/title}" level="H1" wrapping="true" class="pfProjName"/>
                                                <Title text="{vm>/module/subtitle}" level="H2" wrapping="true" class="pfProjKor"/>
                                                <Text text="{vm>/module/description}" wrapping="true" class="pfProjSummary"/>
                                            </VBox>
                                            <Button text="&#8592; Dashboard" press=".onBackToDashboard" class="pfBackBtn"/>
                                        </HBox>

                                        <FlexBox renderType="Bare" class="pfBentoGrid" width="100%">

                                            <!-- Visual / Demo : ScreenUrls 갤러리 → 없으면 플레이스홀더 -->
                                            <VBox class="pfBentoCard pfBentoVisual">
                                                <Text text="{vm>/module/videoLabel}" class="pfCardLabel"/>
                                                <Carousel visible="{= ${vm>/module/gallery}.length > 0 }"
                                                          pages="{vm>/module/gallery}" class="pfGallery">
                                                    <VBox alignItems="Center" class="pfGallerySlide">
                                                        <Image src="{path: 'vm>url', formatter: '.fmtMedia'}"
                                                               densityAware="false" class="pfGalleryImage"/>
                                                        <Text text="{vm>title}" class="pfGalleryCaption"/>
                                                    </VBox>
                                                </Carousel>
                                                <VBox visible="{= ${vm>/module/gallery}.length === 0 }"
                                                      class="pfVisualPlaceholder" alignItems="Center" justifyContent="Center">
                                                    <VBox alignItems="Center">
                                                        <Text text="{vm>/module/code}" class="pfVisualMark">
                                                            <customData>
                                                                <core:CustomData key="domain" writeToDom="true" value="{vm>/module/domain}"/>
                                                            </customData>
                                                        </Text>
                                                        <Text text="{vm>/module/videoLabel}" class="pfVisualTitle"/>
                                                        <Text text="Modules DB의 ScreenUrls 이미지 또는 시연 영상이 배치되는 영역입니다." class="pfVisualSub"/>
                                                    </VBox>
                                                </VBox>
                                                <Button text="영상 보기" press=".onOpenModuleVideo"
                                                        visible="{= !!${vm>/module/videoUrl} }" class="pfBtnPlay pfVideoBtn"/>
                                            </VBox>

                                            <!-- Info -->
                                            <VBox class="pfBentoCard pfBentoInfo">
                                                <VBox class="pfInfoBlock">
                                                    <Text text="OWNER" class="pfInfoLabel"/>
                                                    <Text text="{vm>/module/owner}" class="pfInfoValue"/>
                                                </VBox>
                                                <VBox class="pfInfoBlock">
                                                    <Text text="PROCESS" class="pfInfoLabel"/>
                                                    <Text text="{vm>/module/process}" wrapping="true" class="pfInfoValue"/>
                                                </VBox>
                                                <VBox class="pfInfoBlock">
                                                    <Text text="TABLE / DATA" class="pfInfoLabel"/>
                                                    <HBox items="{vm>/module/tables}" wrap="Wrap" class="pfTagRow">
                                                        <Text text="{vm>text}" class="pfTechTag"/>
                                                    </HBox>
                                                </VBox>
                                            </VBox>

                                            <!-- Features / Tech Points -->
                                            <VBox class="pfBentoCard pfBentoHalf">
                                                <Text text="KEY FEATURES" class="pfCardLabel"/>
                                                <VBox items="{vm>/module/features}" renderType="Bare" class="pfFeatureList">
                                                    <Text text="{vm>text}" wrapping="true" class="pfFeatureItem"/>
                                                </VBox>
                                            </VBox>
                                            <VBox class="pfBentoCard pfBentoHalf">
                                                <Text text="IMPLEMENTATION POINTS" class="pfCardLabel"/>
                                                <VBox items="{vm>/module/techPoints}" renderType="Bare" class="pfFeatureList">
                                                    <Text text="{vm>text}" wrapping="true" class="pfFeatureItem"/>
                                                </VBox>
                                            </VBox>

                                            <!-- Process Flow -->
                                            <VBox class="pfBentoCard pfBentoFull"
                                                  visible="{= ${vm>/module/processSteps}.length > 0 }">
                                                <Text text="END-TO-END PROCESS" class="pfCardLabel"/>
                                                <FlexBox renderType="Bare" items="{vm>/module/processSteps}" class="pfProcessFlow">
                                                    <VBox class="pfProcessStep" alignItems="Center" justifyContent="Center">
                                                        <Text text="{vm>text}" wrapping="true" class="pfProcessStepText"/>
                                                    </VBox>
                                                </FlexBox>
                                            </VBox>

                                            <!-- 게시글 목록 -->
                                            <VBox class="pfBentoCard pfBentoFull"
                                                  visible="{= ${vm>/module/posts}.length > 0 }">
                                                <Text text="FUNCTION POSTS" class="pfCardLabel"/>
                                                <List id="modulePostList" items="{vm>/module/posts}" showSeparators="None"
                                                      backgroundDesign="Transparent" class="pfProjectGrid pfPostGrid"
                                                      itemPress=".onModulePostPress">
                                                    <CustomListItem type="Active" class="pfProjectCard">
                                                        <VBox class="pfProjectCardInner">
                                                            <HBox wrap="Wrap" class="pfBadgeRow" items="{vm>tags}">
                                                                <Text text="{vm>name}" class="pfBadge pfBadgeNeutral"/>
                                                            </HBox>
                                                            <Title text="{vm>title}" level="H3" wrapping="true" class="pfProjectCardTitle"/>
                                                            <Text text="{vm>summary}" wrapping="true" class="pfProjectCardDesc"/>
                                                            <HBox justifyContent="SpaceBetween" alignItems="Center"
                                                                  width="100%" class="pfProjectCardBottom">
                                                                <Text text="{vm>owner}" class="pfProjectMeta"/>
                                                                <Text text="&#8594;" class="pfArrow"/>
                                                            </HBox>
                                                        </VBox>
                                                    </CustomListItem>
                                                </List>
                                            </VBox>

                                        </FlexBox>
                                    </VBox>
                                </ScrollContainer>

                                <!-- ── 3. POST 상세 (posts/{Module}/{PostId}.json 바인딩) ── -->
                                <ScrollContainer id="pagePost" height="100%" width="100%"
                                                 vertical="true" horizontal="false">
                                    <VBox id="postInner" class="pfPageInner">

                                        <!-- 로딩 실패 시 오류 상태 (가짜 데이터 금지) -->
                                        <VBox visible="{= !!${vm>/postError} }" class="pfErrorState">
                                            <Title text="게시글을 불러오지 못했습니다" level="H2" class="pfErrorTitle"/>
                                            <Text text="{vm>/postError}" class="pfErrorDesc"/>
                                            <Button text="&#8592; Dashboard로 돌아가기" press=".onBackToDashboard" class="pfBackBtn"/>
                                        </VBox>

                                        <VBox visible="{= !${vm>/postError} }">
                                            <HBox class="pfProjHeader" justifyContent="SpaceBetween"
                                                  alignItems="Start" width="100%" wrap="Wrap">
                                                <VBox class="pfProjHeaderCopy">
                                                    <Text text="{vm>/post/category}" class="pfProjCategory"/>
                                                    <Title text="{vm>/post/title}" level="H1" wrapping="true" class="pfProjName"/>
                                                    <Title text="{vm>/post/subtitle}" level="H2" wrapping="true" class="pfProjKor"/>
                                                    <Text text="{vm>/post/summary}" wrapping="true" class="pfProjSummary"/>
                                                    <HBox items="{vm>/post/tags}" wrap="Wrap" class="pfBadgeRow pfHeaderBadges">
                                                        <Text text="{vm>name}" class="pfBadge pfBadgeNeutral"/>
                                                    </HBox>
                                                </VBox>
                                                <Button text="&#8592; Back" press=".onBack" class="pfBackBtn"/>
                                            </HBox>

                                            <FlexBox renderType="Bare" class="pfBentoGrid" width="100%">

                                                <!-- 갤러리 (screenshots + bodyImages) / 빈 상태 -->
                                                <VBox class="pfBentoCard pfBentoVisual">
                                                    <Text text="SCREEN / DEMO" class="pfCardLabel"/>
                                                    <Carousel visible="{= ${vm>/post/gallery}.length > 0 }"
                                                              pages="{vm>/post/gallery}" class="pfGallery">
                                                        <VBox alignItems="Center" class="pfGallerySlide">
                                                            <Image src="{path: 'vm>url', formatter: '.fmtMedia'}"
                                                                   densityAware="false" class="pfGalleryImage"/>
                                                            <Text text="{vm>title}" class="pfGalleryCaption"/>
                                                        </VBox>
                                                    </Carousel>
                                                    <VBox visible="{= ${vm>/post/gallery}.length === 0 }"
                                                          class="pfVisualPlaceholder" alignItems="Center" justifyContent="Center">
                                                        <VBox alignItems="Center">
                                                            <Text text="{vm>/post/moduleId}" class="pfVisualMark">
                                                                <customData>
                                                                    <core:CustomData key="domain" writeToDom="true" value="{vm>/post/domain}"/>
                                                                </customData>
                                                            </Text>
                                                            <Text text="등록된 화면 캡처가 없습니다" class="pfVisualTitle"/>
                                                            <Text text="Notion 게시글의 ScreenUrls 또는 본문 이미지가 이 영역에 표시됩니다."
                                                                  class="pfVisualSub"/>
                                                        </VBox>
                                                    </VBox>
                                                    <Button text="시연 영상 보기" press=".onOpenPostVideo"
                                                            visible="{= !!${vm>/post/videoUrl} }" class="pfBtnPlay pfVideoBtn"/>
                                                </VBox>

                                                <!-- Info -->
                                                <VBox class="pfBentoCard pfBentoInfo">
                                                    <VBox class="pfInfoBlock" visible="{= !!${vm>/post/owner} }">
                                                        <Text text="OWNER" class="pfInfoLabel"/>
                                                        <Text text="{vm>/post/owner}" class="pfInfoValue"/>
                                                    </VBox>
                                                    <VBox class="pfInfoBlock" visible="{= ${vm>/post/process}.length > 0 }">
                                                        <Text text="PROCESS" class="pfInfoLabel"/>
                                                        <Text text="{vm>/post/processText}" wrapping="true" class="pfInfoValue"/>
                                                    </VBox>
                                                    <VBox class="pfInfoBlock" visible="{= ${vm>/post/tables}.length > 0 }">
                                                        <Text text="TABLE / DATA" class="pfInfoLabel"/>
                                                        <HBox items="{vm>/post/tables}" wrap="Wrap" class="pfTagRow">
                                                            <Text text="{vm>text}" class="pfTechTag"/>
                                                        </HBox>
                                                    </VBox>
                                                </VBox>

                                                <!-- 구현 포인트 (속성 기반) -->
                                                <VBox class="pfBentoCard pfBentoHalf"
                                                      visible="{= ${vm>/post/implementation}.length > 0 }">
                                                    <Text text="IMPLEMENTATION POINTS" class="pfCardLabel"/>
                                                    <VBox items="{vm>/post/implementation}" renderType="Bare" class="pfFeatureList">
                                                        <Text text="{vm>text}" wrapping="true" class="pfFeatureItem"/>
                                                    </VBox>
                                                </VBox>

                                                <!-- 트러블슈팅 -->
                                                <VBox class="pfBentoCard pfBentoHalf"
                                                      visible="{= ${vm>/post/troubleShooting}.length > 0 }">
                                                    <Text text="TROUBLESHOOTING" class="pfCardLabel"/>
                                                    <VBox items="{vm>/post/troubleShooting}" renderType="Bare" class="pfFeatureList">
                                                        <VBox class="pfTroubleItem">
                                                            <Text text="{vm>problem}" wrapping="true" class="pfFeatureItem"/>
                                                            <Text text="{vm>solution}" wrapping="true"
                                                                  visible="{= !!${vm>solution} }" class="pfTroubleSolution"/>
                                                        </VBox>
                                                    </VBox>
                                                </VBox>

                                                <!-- 본문 섹션 (Notion 블록 → sections 반복 바인딩) -->
                                                <VBox items="{vm>/post/sections}" renderType="Bare" class="pfSectionsWrap">
                                                    <VBox class="pfBentoCard pfBentoFull pfBodySection">
                                                        <Text text="{vm>heading}" class="pfCardLabel"/>
                                                        <FormattedText htmlText="{vm>bodyHtml}" class="pfBodyCopy"/>
                                                    </VBox>
                                                </VBox>

                                            </FlexBox>
                                        </VBox>
                                    </VBox>
                                </ScrollContainer>

                                <!-- ── 4. SKILLS ── -->
                                <ScrollContainer id="pageSkills" height="100%" width="100%"
                                                 vertical="true" horizontal="false">
                                    <VBox id="skillsInner" class="pfPageInner">
                                        <Text text="{site>/skills/eyebrow}" class="pfEyebrow"/>
                                        <Title text="{site>/skills/title}" level="H1" wrapping="true" class="pfPageTitle"/>
                                        <Text text="{site>/skills/desc}" wrapping="true" class="pfPageDesc"/>

                                        <FlexBox renderType="Bare" items="{site>/skills/cards}"
                                                 class="pfSkillGrid pfSection">
                                            <VBox class="pfSkillCard">
                                                <Text text="{site>badge}" class="pfBadge pfBadgeType">
                                                    <customData>
                                                        <core:CustomData key="type" writeToDom="true" value="{site>type}"/>
                                                    </customData>
                                                </Text>
                                                <Title text="{site>title}" level="H3" class="pfSkillTitle"/>
                                                <Text text="{site>desc}" wrapping="true" class="pfSkillDesc"/>
                                                <HBox items="{site>tags}" wrap="Wrap" class="pfSkillTags">
                                                    <Text text="{site>text}" class="pfPill"/>
                                                </HBox>
                                            </VBox>
                                        </FlexBox>
                                    </VBox>
                                </ScrollContainer>

                                <!-- ── 5. CAREER & CONTACT ── -->
                                <ScrollContainer id="pageCareer" height="100%" width="100%"
                                                 vertical="true" horizontal="false">
                                    <VBox id="careerInner" class="pfPageInner">
                                        <Text text="{site>/career/eyebrow}" class="pfEyebrow"/>
                                        <FormattedText htmlText="{path: 'site>/career/title', formatter: '.fmtBr'}"
                                                       class="pfPageTitle"/>
                                        <Text text="{site>/career/desc}" wrapping="true" class="pfPageDesc"/>

                                        <VBox items="{site>/career/timeline}" renderType="Bare"
                                              class="pfTimeline pfSection">
                                            <VBox class="pfTimelineItem">
                                                <Text text="{site>year}" class="pfTimelineYear"/>
                                                <Title text="{site>title}" level="H3" class="pfTimelineTitle" wrapping="true"/>
                                                <Text text="{site>desc}" wrapping="true" class="pfTimelineDesc"/>
                                            </VBox>
                                        </VBox>

                                        <VBox class="pfContactCard">
                                            <Title text="{site>/career/contact/title}" level="H3" class="pfContactTitle"/>
                                            <Text text="{site>/career/contact/body}" wrapping="true" class="pfContactBody"/>
                                            <HBox items="{site>/career/contact/links}" wrap="Wrap" class="pfContactLinks">
                                                <Button text="{site>label}" press=".onOpenLink" class="pfBtnSecondary"/>
                                            </HBox>
                                        </VBox>
                                    </VBox>
                                </ScrollContainer>

                            </NavContainer>
                        </FlexBox>

                    </content>
                </Page>
            </pages>
        </App>
    </Shell>
</mvc:View>
